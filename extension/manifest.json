{
  "manifest_version": 3,
  "name": "SafeApply",
  "description": "Know if a job is real before you apply. SafeApply scans visible job-page text and creates a trust scorecard.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SafeApply job trust score",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["activeTab", "scripting"]
}
